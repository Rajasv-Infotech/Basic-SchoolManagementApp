@page "/fee-records"
@using SchoolManagementApp.Models
@using SchoolManagementApp.Services
@inject IDataService<FeeRecord> FeeService
@inject IDataService<FeePaymentReceipt> ReceiptService
@inject IDataService<AcademicSession> SessionService
@inject IDataService<ClassSection> ClassSectionService
@inject IDataService<FeeHead> FeeHeadService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h3><i class="bi bi-journal-text"></i> Fee Records</h3>
            <p class="text-muted mb-0">Track student-wise fee charges, paid amount, and pending balance here.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageCss alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="ClearMessage"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-3 mb-2">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <small>Total Records</small>
                    <h3>@fees.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <small>Total Amount</small>
                    <h3>₹@fees.Sum(f => f.TotalAmount).ToString("N0")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <small>Paid Amount</small>
                    <h3>₹@fees.Sum(f => f.PaidAmount).ToString("N0")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <small>Pending Amount</small>
                    <h3>₹@fees.Where(f => f.Status != "Paid").Sum(f => f.BalanceAmount).ToString("N0")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <h5 class="mb-0">Fee Records</h5>
            <button class="btn btn-outline-success btn-sm" @onclick="ExportFeeRecordsToExcel" disabled="@(!FilteredFees.Any())">
                <i class="bi bi-file-earmark-excel"></i> Excel Export
            </button>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3 align-items-end fee-filter-row">
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Search</label>
                    <input class="form-control" placeholder="Student / receipt" @bind="searchTerm" @bind:event="oninput" />
                </div>
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Session</label>
                    <select class="form-select" value="@filterSessionId" @onchange="OnRecordFilterSessionChanged">
                        <option value="">All Sessions</option>
                        @foreach (var session in sessions.OrderByDescending(s => s.StartDate))
                        {
                            <option value="@session.Id">@session.Name</option>
                        }
                    </select>
                </div>
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Class-Section</label>
                    <select class="form-select" value="@filterClassSectionId" @onchange="OnRecordFilterClassSectionChanged">
                        <option value="">All Class-Sections</option>
                        @foreach (var cs in RecordFilterClassSections)
                        {
                            <option value="@cs.Id">@cs.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Status</label>
                    <select class="form-select" @bind="filterStatus">
                        <option value="">All Status</option>
                        <option>Pending</option>
                        <option>Paid</option>
                        <option>Overdue</option>
                        <option>Partial</option>
                    </select>
                </div>
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Fee Head</label>
                    <select class="form-select" @bind="filterFeeHead">
                        <option value="">All Fee Heads</option>
                        @foreach (var head in feeHeads.OrderBy(h => h.Name))
                        {
                            <option value="@head.Name">@head.Name</option>
                        }
                    </select>
                </div>
                <div class="col-xl-1 col-lg-3 col-md-6">
                    <label class="form-label small text-muted mb-1">Type</label>
                    <select class="form-select" @bind="filterChargeType">
                        <option value="">All Types</option>
                        <option value="Common">Common</option>
                        <option value="Student">Student-only</option>
                    </select>
                </div>
                <div class="col-xl-1 col-lg-3 col-md-6 text-lg-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
                </div>
            </div>

            @if (FilteredFees.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Session</th>
                                <th>Class-Section</th>
                                <th>Fee Head</th>
                                <th>Type</th>
                                <th>Month</th>
                                <th>Due Date</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">Paid</th>
                                <th class="text-end">Balance</th>
                                <th>Status</th>
                                <th>Receipt</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fee in FilteredFees)
                            {
                                <tr>
                                    <td>@fee.StudentName<br /><small class="text-muted">Roll: @fee.RollNumber</small></td>
                                    <td>@fee.SessionName</td>
                                    <td>@fee.ClassSectionName</td>
                                    <td>@fee.FeeType</td>
                                    <td><span class="badge @(fee.ChargeType == "Common" ? "bg-primary" : "bg-info")">@(fee.ChargeType == "Common" ? "Common" : "Student-only")</span></td>
                                    <td>@fee.FeeMonth</td>
                                    <td>@fee.DueDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">₹@fee.TotalAmount.ToString("N2")</td>
                                    <td class="text-end">₹@fee.PaidAmount.ToString("N2")</td>
                                    <td class="text-end">₹@fee.BalanceAmount.ToString("N2")</td>
                                    <td><span class="badge @GetStatusBadge(fee.Status)">@fee.Status</span></td>
                                    <td>@fee.ReceiptNumber</td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => PayFee(fee)" disabled="@IsFeePayDisabled(fee)">Pay Fees</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFee(fee.Id)">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="7">Total</th>
                                <th class="text-end">₹@FilteredFees.Sum(f => f.TotalAmount).ToString("N2")</th>
                                <th class="text-end">₹@FilteredFees.Sum(f => f.PaidAmount).ToString("N2")</th>
                                <th class="text-end">₹@FilteredFees.Sum(f => f.BalanceAmount).ToString("N2")</th>
                                <th colspan="3"></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">No fee record has been created yet.</div>
            }
        </div>
    </div>
</div>

@if (showDeleteConfirm && pendingDeleteFee != null)
{
    <div class="modal-backdrop show"></div>
    <div class="modal show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modern-confirm-modal">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-1"><i class="bi bi-exclamation-triangle text-danger"></i> Confirm Fee Delete</h5>
                        <small class="text-muted">Please review this fee record before deleting.</small>
                    </div>
                    <button type="button" class="btn-close" @onclick="CancelDeleteFee"></button>
                </div>
                <div class="modal-body">
                    <div class="confirm-summary">
                        <div><strong>Student:</strong> @pendingDeleteFee.StudentName</div>
                        <div><strong>Fee Head:</strong> @pendingDeleteFee.FeeType</div>
                        <div><strong>Total Amount:</strong> ₹@pendingDeleteFee.TotalAmount.ToString("N2")</div>
                        <div><strong>Paid Amount:</strong> ₹@pendingDeleteFee.PaidAmount.ToString("N2")</div>
                        <div><strong>Balance:</strong> ₹@pendingDeleteFee.BalanceAmount.ToString("N2")</div>
                    </div>
                    @if (pendingDeleteHasPayment)
                    {
                        <div class="alert alert-warning mt-3 mb-0">
                            <strong>Warning:</strong> A receipt has already been generated or an amount has been paid for this fee.
                            @if (!string.IsNullOrWhiteSpace(pendingDeleteReceiptText))
                            {
                                <div class="mt-1"><strong>Receipt No:</strong> @pendingDeleteReceiptText</div>
                            }
                        </div>
                    }
                    <p class="mt-3 mb-0">Do you want to delete this fee record?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDeleteFee">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteFee">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FeeRecord> fees = new();
    private List<AcademicSession> sessions = new();
    private List<ClassSection> classSections = new();
    private List<FeeHead> feeHeads = new();

    private string message = string.Empty;
    private string messageCss = "alert-success";
    private string searchTerm = string.Empty;
    private string filterStatus = string.Empty;
    private string filterFeeHead = string.Empty;
    private string filterChargeType = string.Empty;
    private string filterSessionId = string.Empty;
    private string filterClassSectionId = string.Empty;
    private bool showDeleteConfirm;
    private FeeRecord? pendingDeleteFee;
    private bool pendingDeleteHasPayment;
    private string pendingDeleteReceiptText = string.Empty;

    private IEnumerable<ClassSection> RecordFilterClassSections => classSections
        .Where(c => string.IsNullOrWhiteSpace(filterSessionId) || c.SessionId == filterSessionId)
        .OrderBy(c => c.SessionName)
        .ThenBy(c => c.ClassName)
        .ThenBy(c => c.SectionName);

    private IEnumerable<FeeRecord> FilteredFees => fees.Where(f =>
        (string.IsNullOrWhiteSpace(searchTerm) ||
            (f.StudentName ?? string.Empty).Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (f.ReceiptNumber ?? string.Empty).Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (f.RollNumber ?? string.Empty).Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(filterSessionId) || f.SessionId == filterSessionId) &&
        (string.IsNullOrWhiteSpace(filterClassSectionId) || f.ClassSectionId == filterClassSectionId) &&
        (string.IsNullOrWhiteSpace(filterStatus) || f.Status == filterStatus) &&
        (string.IsNullOrWhiteSpace(filterFeeHead) || f.FeeType == filterFeeHead) &&
        (string.IsNullOrWhiteSpace(filterChargeType) || f.ChargeType == filterChargeType))
        .OrderByDescending(f => f.CreatedDate);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        fees = await FeeService.GetAllAsync();
        sessions = await SessionService.GetAllAsync();
        classSections = await ClassSectionService.GetAllAsync();
        feeHeads = await FeeHeadService.GetAllAsync();

        foreach (var fee in fees.Where(f => f.Status == "Pending" && f.DueDate.Date < DateTime.Today))
        {
            fee.Status = "Overdue";
            fee.LastUpdated = DateTime.Now;
            await FeeService.UpdateAsync(fee);
        }
    }

    private void OnRecordFilterSessionChanged(ChangeEventArgs e)
    {
        filterSessionId = e.Value?.ToString() ?? string.Empty;
        filterClassSectionId = string.Empty;
    }

    private void OnRecordFilterClassSectionChanged(ChangeEventArgs e)
    {
        filterClassSectionId = e.Value?.ToString() ?? string.Empty;
    }

    private async Task DeleteFee(string id)
    {
        var fee = fees.FirstOrDefault(f => f.Id == id) ?? await FeeService.GetByIdAsync(id);
        if (fee == null)
        {
            ShowError("Fee record not found.");
            return;
        }

        var receipts = await ReceiptService.GetAllAsync();
        var relatedReceipts = receipts
            .Where(r => r.Items.Any(i => i.FeeRecordId == fee.Id) || (!string.IsNullOrWhiteSpace(fee.ReceiptNumber) && r.ReceiptNumber == fee.ReceiptNumber))
            .ToList();

        var receiptNumbers = relatedReceipts.Select(r => r.ReceiptNumber)
            .Append(fee.ReceiptNumber)
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .Distinct()
            .ToList();

        pendingDeleteFee = fee;
        pendingDeleteHasPayment = fee.PaidAmount > 0 || !string.IsNullOrWhiteSpace(fee.ReceiptNumber) || relatedReceipts.Any();
        pendingDeleteReceiptText = string.Join(", ", receiptNumbers);
        showDeleteConfirm = true;
    }

    private void CancelDeleteFee()
    {
        showDeleteConfirm = false;
        pendingDeleteFee = null;
        pendingDeleteHasPayment = false;
        pendingDeleteReceiptText = string.Empty;
    }

    private async Task ConfirmDeleteFee()
    {
        if (pendingDeleteFee == null)
        {
            CancelDeleteFee();
            return;
        }

        var feeId = pendingDeleteFee.Id;
        CancelDeleteFee();
        await FeeService.DeleteAsync(feeId);
        ShowSuccess("Fee record deleted successfully.");
        await LoadData();
    }

    private void PayFee(FeeRecord fee)
    {
        if (IsFeePayDisabled(fee))
        {
            ShowError("This fee is already paid.");
            return;
        }

        var studentId = Uri.EscapeDataString(fee.StudentId ?? string.Empty);
        var feeId = Uri.EscapeDataString(fee.Id ?? string.Empty);
        Navigation.NavigateTo($"/fees-pay?studentId={studentId}&feeId={feeId}");
    }

    private static bool IsFeePayDisabled(FeeRecord fee)
    {
        return fee.BalanceAmount <= 0 || fee.Status == "Paid";
    }

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        filterStatus = string.Empty;
        filterFeeHead = string.Empty;
        filterChargeType = string.Empty;
        filterSessionId = string.Empty;
        filterClassSectionId = string.Empty;
    }

    private async Task ExportFeeRecordsToExcel()
    {
        var exportRows = FilteredFees.Select(fee => new FeeRecordExportRow
        {
            Student = fee.StudentName,
            RollNumber = fee.RollNumber,
            Session = fee.SessionName,
            ClassSection = fee.ClassSectionName,
            FeeHead = fee.FeeType,
            Type = fee.ChargeType == "Common" ? "Common" : "Student-only",
            Month = fee.FeeMonth,
            DueDate = fee.DueDate.ToString("dd-MMM-yyyy"),
            Amount = fee.TotalAmount.ToString("N2"),
            Paid = fee.PaidAmount.ToString("N2"),
            Balance = fee.BalanceAmount.ToString("N2"),
            Status = fee.Status,
            ReceiptNumber = fee.ReceiptNumber,
            PaymentDate = fee.PaymentDate?.ToString("dd-MMM-yyyy") ?? string.Empty,
            PaymentMethod = fee.PaymentMethod,
            TransactionId = fee.TransactionId,
            Remarks = fee.Remarks
        }).ToList();

        var columns = new[]
        {
            new[] { "student", "Student" },
            new[] { "rollNumber", "Roll Number" },
            new[] { "session", "Session" },
            new[] { "classSection", "Class-Section" },
            new[] { "feeHead", "Fee Head" },
            new[] { "type", "Type" },
            new[] { "month", "Month" },
            new[] { "dueDate", "Due Date" },
            new[] { "amount", "Amount" },
            new[] { "paid", "Paid" },
            new[] { "balance", "Balance" },
            new[] { "status", "Status" },
            new[] { "receiptNumber", "Receipt No" },
            new[] { "paymentDate", "Payment Date" },
            new[] { "paymentMethod", "Payment Method" },
            new[] { "transactionId", "Transaction Id" },
            new[] { "remarks", "Remarks" }
        };

        await JSRuntime.InvokeVoidAsync("downloadExcelRows", columns, exportRows, "fee-records");
    }

    private sealed class FeeRecordExportRow
    {
        public string Student { get; set; } = string.Empty;
        public string RollNumber { get; set; } = string.Empty;
        public string Session { get; set; } = string.Empty;
        public string ClassSection { get; set; } = string.Empty;
        public string FeeHead { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Month { get; set; } = string.Empty;
        public string DueDate { get; set; } = string.Empty;
        public string Amount { get; set; } = string.Empty;
        public string Paid { get; set; } = string.Empty;
        public string Balance { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string ReceiptNumber { get; set; } = string.Empty;
        public string PaymentDate { get; set; } = string.Empty;
        public string PaymentMethod { get; set; } = string.Empty;
        public string TransactionId { get; set; } = string.Empty;
        public string Remarks { get; set; } = string.Empty;
    }

    private string GetStatusBadge(string status)
    {
        return status switch
        {
            "Paid" => "bg-success",
            "Overdue" => "bg-danger",
            "Partial" => "bg-info",
            _ => "bg-warning text-dark"
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCss = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCss = "alert-danger";
    }

    private void ClearMessage()
    {
        message = string.Empty;
    }
}
