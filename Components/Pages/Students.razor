@page "/students"
@using SchoolManagementApp.Models
@using SchoolManagementApp.Services
@inject IDataService<Student> StudentService
@inject IDataService<AcademicSession> SessionService
@inject IDataService<ClassSection> ClassSectionService
@inject IJSRuntime JSRuntime

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h3>Student Admission</h3>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary" @onclick="ShowAddForm">
                <i class="bi bi-plus-circle"></i> New Admission
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="ClearError"></button>
        </div>
    }

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>@(isEditing ? "Edit Student Admission" : "New Student Admission")</h5>
            </div>
            <div class="card-body">
                <EditForm Model="currentStudent" OnValidSubmit="SaveStudent">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Full Name</label>
                            <InputText class="form-control" @bind-Value="currentStudent.FullName" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="currentStudent.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone</label>
                            <InputText class="form-control" @bind-Value="currentStudent.Phone" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Session</label>
                            <select class="form-select" value="@currentStudent.SessionId" @onchange="OnSessionChanged">
                                <option value="">Select Session</option>
                                @foreach (var session in sessions.OrderByDescending(s => s.StartDate))
                                {
                                    <option value="@session.Id">@session.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Class - Section</label>
                            <select class="form-select" value="@currentStudent.ClassSectionId" @onchange="OnClassSectionChanged">
                                <option value="">Select Class Section</option>
                                @foreach (var item in AvailableClassSections)
                                {
                                    <option value="@item.Id">@item.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Roll Number</label>
                            <InputText class="form-control" @bind-Value="currentStudent.RollNumber" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date of Birth</label>
                            <InputDate class="form-control" @bind-Value="currentStudent.DateOfBirth" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Admission Date</label>
                            <InputDate class="form-control" @bind-Value="currentStudent.EnrollmentDate" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <InputTextArea class="form-control" @bind-Value="currentStudent.Address" rows="2" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Father's Name</label>
                            <InputText class="form-control" @bind-Value="currentStudent.FatherName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Father's Contact</label>
                            <InputText class="form-control" @bind-Value="currentStudent.FatherContact" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mother's Name</label>
                            <InputText class="form-control" @bind-Value="currentStudent.MotherName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mother's Contact</label>
                            <InputText class="form-control" @bind-Value="currentStudent.MotherContact" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Guardian Name</label>
                            <InputText class="form-control" @bind-Value="currentStudent.GuardianName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Guardian Contact</label>
                            <InputText class="form-control" @bind-Value="currentStudent.GuardianContact" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="currentStudent.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@isBusy">
                            @(isBusy ? "Saving..." : "Save")
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="CancelForm" disabled="@isBusy">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-xl-4 col-lg-4 col-md-6">
                    <input type="text" class="form-control" placeholder="Search students..." @bind="searchTerm" @bind:event="oninput" />
                </div>
                <div class="col-xl-3 col-lg-3 col-md-6">
                    <select class="form-select" @bind="filterSessionId">
                        <option value="">All Sessions</option>
                        @foreach (var session in sessions.OrderByDescending(s => s.StartDate))
                        {
                            <option value="@session.Id">@session.Name</option>
                        }
                    </select>
                </div>
                <div class="col-xl-3 col-lg-3 col-md-6">
                    <select class="form-select" @bind="filterClassSectionId">
                        <option value="">All Class Sections</option>
                        @foreach (var item in FilterClassSections)
                        {
                            <option value="@item.Id">@item.SessionName - @item.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-xl-2 col-lg-2 col-md-6 text-lg-end">
                    <button type="button" class="btn btn-outline-success excel-export-btn w-100" title="Export to Excel" @onclick="ExportStudentsToExcel" disabled="@isBusy">
                        <i class="bi bi-file-earmark-excel"></i> Excel Export
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Roll No</th>
                            <th>Name</th>
                            <th>Session</th>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Father</th>
                            <th>Mother</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredStudents.Any())
                        {
                            @foreach (var student in FilteredStudents)
                            {
                                <tr>
                                    <td>@student.RollNumber</td>
                                    <td>@GetStudentDisplayName(student)</td>
                                    <td>@student.SessionName</td>
                                    <td>@student.Class</td>
                                    <td>@student.Section</td>
                                    <td>@student.Email</td>
                                    <td>@student.Phone</td>
                                    <td>@student.FatherName</td>
                                    <td>@student.MotherName</td>
                                    <td>
                                        <span class="badge @(student.IsActive ? "bg-success" : "bg-danger")">
                                            @(student.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning me-1" @onclick="() => EditStudent(student)" disabled="@isBusy">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteStudent(student.Id)" disabled="@isBusy">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted">No students found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!students.Any())
            {
                <div class="alert alert-info mt-3">No students found. Add your first student admission!</div>
            }
        </div>
    </div>
</div>

@code {
    private List<Student> students = new();
    private List<AcademicSession> sessions = new();
    private List<ClassSection> classSections = new();
    private Student currentStudent = new();
    private bool showForm = false;
    private bool isEditing = false;
    private bool isBusy = false;
    private string searchTerm = string.Empty;
    private string errorMessage = string.Empty;
    private string filterSessionId = string.Empty;
    private string filterClassSectionId = string.Empty;

    private IEnumerable<ClassSection> AvailableClassSections => classSections
        .Where(c => c.IsActive && c.SessionId == currentStudent.SessionId)
        .OrderBy(c => c.ClassName)
        .ThenBy(c => c.SectionName);

    private IEnumerable<ClassSection> FilterClassSections => classSections
        .Where(c => string.IsNullOrWhiteSpace(filterSessionId) || c.SessionId == filterSessionId)
        .OrderByDescending(c => c.SessionName)
        .ThenBy(c => c.ClassName)
        .ThenBy(c => c.SectionName);

    private IEnumerable<Student> FilteredStudents => students
        .Where(s => string.IsNullOrWhiteSpace(filterSessionId) || s.SessionId == filterSessionId)
        .Where(s => string.IsNullOrWhiteSpace(filterClassSectionId) || s.ClassSectionId == filterClassSectionId)
        .Where(s => string.IsNullOrWhiteSpace(searchTerm) ||
            (GetStudentDisplayName(s).Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (s.FatherName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.MotherName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.GuardianName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.RollNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.SessionName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Class?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Section?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isBusy = true;
            ClearError();

            sessions = await SessionService.GetAllAsync();
            classSections = await ClassSectionService.GetAllAsync();
            students = await StudentService.GetAllAsync();
            SyncStudentDisplayValues();
        }
        catch (Exception ex)
        {
            students = new List<Student>();
            sessions = new List<AcademicSession>();
            classSections = new List<ClassSection>();
            errorMessage = $"Failed to load students: {ex.Message}";
            await ShowMessageAsync("Error", errorMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void SyncStudentDisplayValues()
    {
        foreach (var student in students)
        {
            NormalizeStudentNames(student);

            var session = sessions.FirstOrDefault(s => s.Id == student.SessionId);
            if (session is not null)
                student.SessionName = session.Name;

            var classSection = classSections.FirstOrDefault(c => c.Id == student.ClassSectionId);
            if (classSection is not null)
            {
                student.Class = classSection.ClassName;
                student.Section = classSection.SectionName;
                student.SessionId = classSection.SessionId;
                student.SessionName = classSection.SessionName;
            }
        }
    }

    private void ShowAddForm()
    {
        ClearError();

        var activeSession = sessions.FirstOrDefault(s => s.IsActive) ?? sessions.FirstOrDefault();
        currentStudent = new Student
        {
            IsActive = true,
            EnrollmentDate = DateTime.Today,
            SessionId = activeSession?.Id ?? string.Empty,
            SessionName = activeSession?.Name ?? string.Empty
        };

        isEditing = false;
        showForm = true;
    }

    private void EditStudent(Student student)
    {
        ClearError();

        currentStudent = new Student
        {
            Id = student.Id,
            FullName = GetStudentDisplayName(student),
            FirstName = student.FirstName,
            LastName = student.LastName,
            Email = student.Email,
            Phone = student.Phone,
            SessionId = student.SessionId,
            SessionName = student.SessionName,
            ClassSectionId = student.ClassSectionId,
            Class = student.Class,
            Section = student.Section,
            RollNumber = student.RollNumber,
            DateOfBirth = student.DateOfBirth,
            Address = student.Address,
            FatherName = student.FatherName,
            MotherName = student.MotherName,
            FatherContact = student.FatherContact,
            MotherContact = student.MotherContact,
            GuardianName = student.GuardianName,
            GuardianContact = student.GuardianContact,
            ParentName = student.ParentName,
            ParentContact = student.ParentContact,
            EnrollmentDate = student.EnrollmentDate,
            IsActive = student.IsActive
        };

        isEditing = true;
        showForm = true;
    }

    private void OnSessionChanged(ChangeEventArgs e)
    {
        currentStudent.SessionId = e.Value?.ToString() ?? string.Empty;
        currentStudent.ClassSectionId = string.Empty;
        currentStudent.Class = string.Empty;
        currentStudent.Section = string.Empty;

        var session = sessions.FirstOrDefault(s => s.Id == currentStudent.SessionId);
        currentStudent.SessionName = session?.Name ?? string.Empty;
    }

    private void OnClassSectionChanged(ChangeEventArgs e)
    {
        currentStudent.ClassSectionId = e.Value?.ToString() ?? string.Empty;
        var classSection = classSections.FirstOrDefault(c => c.Id == currentStudent.ClassSectionId);
        if (classSection is not null)
        {
            currentStudent.SessionId = classSection.SessionId;
            currentStudent.SessionName = classSection.SessionName;
            currentStudent.Class = classSection.ClassName;
            currentStudent.Section = classSection.SectionName;
        }
        else
        {
            currentStudent.Class = string.Empty;
            currentStudent.Section = string.Empty;
        }
    }

    private async Task SaveStudent()
    {
        try
        {
            isBusy = true;
            ClearError();

            NormalizeStudentNames(currentStudent);

            if (string.IsNullOrWhiteSpace(currentStudent.FullName))
            {
                errorMessage = "Please enter student full name.";
                return;
            }

            if (string.IsNullOrWhiteSpace(currentStudent.SessionId))
            {
                errorMessage = "Please select a session.";
                return;
            }

            var classSection = classSections.FirstOrDefault(c => c.Id == currentStudent.ClassSectionId && c.SessionId == currentStudent.SessionId);
            if (classSection is null)
            {
                errorMessage = "Please select class-section from selected session.";
                return;
            }

            if (students.Any(s => s.Id != currentStudent.Id &&
                s.SessionId == currentStudent.SessionId &&
                s.ClassSectionId == currentStudent.ClassSectionId &&
                s.RollNumber.Equals(currentStudent.RollNumber, StringComparison.OrdinalIgnoreCase)))
            {
                errorMessage = "This roll number already exists in selected session and class-section.";
                return;
            }

            currentStudent.SessionId = classSection.SessionId;
            currentStudent.SessionName = classSection.SessionName;
            currentStudent.ClassSectionId = classSection.Id;
            currentStudent.Class = classSection.ClassName;
            currentStudent.Section = classSection.SectionName;

            if (isEditing)
            {
                await StudentService.UpdateAsync(currentStudent);
                await ShowMessageAsync("Success", "Student admission updated successfully.");
            }
            else
            {
                await StudentService.AddAsync(currentStudent);
                await ShowMessageAsync("Success", "Student admission added successfully.");
            }

            await LoadData();
            CancelForm();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save student: {ex.Message}";
            await ShowMessageAsync("Error", errorMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteStudent(string? id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            await ShowMessageAsync("Error", "Invalid student id.");
            return;
        }

        try
        {
            ClearError();

            var confirmed = await ShowConfirmAsync("Confirm Delete", "Are you sure you want to delete this student admission?", "Yes", "No");
            if (!confirmed)
                return;

            isBusy = true;

            await StudentService.DeleteAsync(id);
            await LoadData();
            await ShowMessageAsync("Success", "Student admission deleted successfully.");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete student: {ex.Message}";
            await ShowMessageAsync("Error", errorMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string GetStudentDisplayName(Student student)
    {
        if (!string.IsNullOrWhiteSpace(student.FullName))
            return student.FullName.Trim();

        return $"{student.FirstName} {student.LastName}".Trim();
    }

    private static void NormalizeStudentNames(Student student)
    {
        if (string.IsNullOrWhiteSpace(student.FullName))
            student.FullName = $"{student.FirstName} {student.LastName}".Trim();

        student.FullName = student.FullName.Trim();

        // Keep old properties populated so older saved records and other pages continue to work.
        student.FirstName = student.FullName;
        student.LastName = string.Empty;

        // Old parent fields are still mirrored for backward compatibility.
        student.ParentName = !string.IsNullOrWhiteSpace(student.FatherName) ? student.FatherName : student.GuardianName;
        student.ParentContact = !string.IsNullOrWhiteSpace(student.FatherContact) ? student.FatherContact : student.GuardianContact;
    }

    private async Task ExportStudentsToExcel()
    {
        var exportRows = FilteredStudents.Select(student => new StudentExportRow
        {
            RollNumber = student.RollNumber,
            FullName = GetStudentDisplayName(student),
            Session = student.SessionName,
            Class = student.Class,
            Section = student.Section,
            Email = student.Email,
            Phone = student.Phone,
            FatherName = student.FatherName,
            FatherContact = student.FatherContact,
            MotherName = student.MotherName,
            MotherContact = student.MotherContact,
            GuardianName = student.GuardianName,
            GuardianContact = student.GuardianContact,
            Address = student.Address,
            AdmissionDate = student.EnrollmentDate.ToString("dd-MMM-yyyy"),
            DateOfBirth = student.DateOfBirth.ToString("dd-MMM-yyyy"),
            Status = student.IsActive ? "Active" : "Inactive"
        }).ToList();

        await JSRuntime.InvokeVoidAsync("downloadStudentsExcel", exportRows);
    }

    private sealed class StudentExportRow
    {
        public string RollNumber { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Session { get; set; } = string.Empty;
        public string Class { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string FatherName { get; set; } = string.Empty;
        public string FatherContact { get; set; } = string.Empty;
        public string MotherName { get; set; } = string.Empty;
        public string MotherContact { get; set; } = string.Empty;
        public string GuardianName { get; set; } = string.Empty;
        public string GuardianContact { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string AdmissionDate { get; set; } = string.Empty;
        public string DateOfBirth { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private void CancelForm()
    {
        showForm = false;
        isEditing = false;
        currentStudent = new Student();
        ClearError();
    }

    private void ClearError() => errorMessage = string.Empty;

    private static Page? GetCurrentPage() => Application.Current?.Windows.FirstOrDefault()?.Page;

    private async Task ShowMessageAsync(string title, string message)
    {
        var page = GetCurrentPage();
        if (page is not null)
            await page.DisplayAlert(title, message, "OK");
    }

    private async Task<bool> ShowConfirmAsync(string title, string message, string accept, string cancel)
    {
        var page = GetCurrentPage();
        return page is not null && await page.DisplayAlert(title, message, accept, cancel);
    }
}
