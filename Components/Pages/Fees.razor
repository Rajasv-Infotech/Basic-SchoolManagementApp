    private void EditFeeHead(FeeHead head)
    {
        currentFeeHead = new FeeHead
        {
            Id = head.Id,
            Name = head.Name,
            Code = head.Code,
            DefaultAmount = head.DefaultAmount,
            Frequency = head.Frequency,
            IsActive = head.IsActive,
            Description = head.Description,
            CreatedDate = head.CreatedDate
        };
        editingFeeHead = true;
        showFeeHeadForm = true;
    }

    private async Task SaveFeeHead()
    {
        if (string.IsNullOrWhiteSpace(currentFeeHead.Name))
        {
            ShowError("Fee head name is required.");
            return;
        }

        currentFeeHead.Name = currentFeeHead.Name.Trim();
        currentFeeHead.Code = currentFeeHead.Code.Trim();

        var duplicate = feeHeads.Any(h =>
            h.Id != currentFeeHead.Id &&
            h.Name.Equals(currentFeeHead.Name, StringComparison.OrdinalIgnoreCase));

        if (duplicate)
        {
            ShowError("This fee head already exists.");
            return;
        }

        if (editingFeeHead)
        {
            await FeeHeadService.UpdateAsync(currentFeeHead);
            ShowSuccess("Fee head updated successfully.");
        }
        else
        {
            await FeeHeadService.AddAsync(currentFeeHead);
            ShowSuccess("Fee head saved successfully.");
        }

        showFeeHeadForm = false;
        await LoadData();
    }

    private async Task DeleteFeeHead(string id)
    {
        if (fees.Any(f => f.FeeHeadId == id))
        {
            ShowError("Fee records exist for this fee head, so it cannot be deleted.");
            return;
        }

        await FeeHeadService.DeleteAsync(id);
        ShowSuccess("Fee head deleted successfully.");
        await LoadData();
    }

