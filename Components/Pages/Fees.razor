    private async Task ApplyCommonFee()
    {
        var session = sessions.FirstOrDefault(s => s.Id == commonSessionId);
        var classSection = classSections.FirstOrDefault(c => c.Id == commonClassSectionId);
        var head = feeHeads.FirstOrDefault(h => h.Id == commonFeeHeadId);

        if (session == null || classSection == null || head == null || commonAmount <= 0)
        {
            ShowError("Session, class-section, fee head, and amount are required.");
            return;
        }

        if (CommonStudentCount == 0)
        {
            ShowError("No active student was found in the selected class-section.");
            return;
        }

        var rule = commonFeeRules.FirstOrDefault(r =>
            r.SessionId == session.Id &&
            r.ClassSectionId == classSection.Id &&
            r.FeeHeadId == head.Id &&
            r.FeeMonth == commonMonth);

        if (rule == null)
        {
            rule = new CommonFeeRule
            {
                SessionId = session.Id,
                SessionName = session.Name,
                ClassSectionId = classSection.Id,
                ClassSectionName = classSection.DisplayName,
                FeeHeadId = head.Id,
                FeeHeadName = head.Name,
                FeeMonth = commonMonth,
                Amount = commonAmount,
                DueDate = commonDueDate,
                Remarks = commonRemarks.Trim(),
                IsActive = true,
                IsDeleted = false,
                CreatedDate = DateTime.Now
            };
            await CommonFeeRuleService.AddAsync(rule);
            commonFeeRules.Add(rule);
        }
        else
        {
            rule.SessionName = session.Name;
            rule.ClassSectionName = classSection.DisplayName;
            rule.FeeHeadName = head.Name;
            rule.Amount = commonAmount;
            rule.DueDate = commonDueDate;
            rule.Remarks = commonRemarks.Trim();
            rule.IsActive = true;
            rule.IsDeleted = false;
            rule.DeletedDate = null;
            await CommonFeeRuleService.UpdateAsync(rule);
        }

        var result = await SyncCommonFeeRule(rule);
        ShowSuccess($"Common fee synced successfully. New charges: {result.created}, existing linked: {result.linked}, protected paid/receipt records kept: {result.protectedCount}.");
        commonFeeHeadId = string.Empty;
        commonAmount = 0;
        commonRemarks = string.Empty;
        await LoadData();
    }

    private async Task ResyncCommonFee(string ruleId)
    {
        var rule = commonFeeRules.FirstOrDefault(r => r.Id == ruleId);
        if (rule == null)
        {
            ShowError("Common fee rule was not found.");
            return;
        }

        var result = await SyncCommonFeeRule(rule);
        if (rule.IsDeleted)
        {
            ShowSuccess($"Deleted common fee resynced. Removed unpaid records: {result.removed}, paid/partial/receipt records kept: {result.protectedCount}.");
        }
        else
        {
            ShowSuccess($"Common fee resynced. New charges: {result.created}, existing linked: {result.linked}, paid/partial/receipt records kept: {result.protectedCount}.");
        }
        await LoadData();
    }

    private Task DeleteCommonFeeRule(string ruleId)
    {
        var rule = commonFeeRules.FirstOrDefault(r => r.Id == ruleId);
        if (rule == null)
        {
            ShowError("Common fee rule was not found.");
            return Task.CompletedTask;
        }

        pendingDeleteCommonRule = rule;
        showCommonDeleteConfirm = true;
        return Task.CompletedTask;
    }

    private void CancelCommonFeeDelete()
    {
        showCommonDeleteConfirm = false;
        pendingDeleteCommonRule = null;
    }

    private async Task ConfirmCommonFeeDelete()
    {
        if (pendingDeleteCommonRule == null)
        {
            CancelCommonFeeDelete();
            return;
        }

        var rule = pendingDeleteCommonRule;
        CancelCommonFeeDelete();

        rule.IsActive = false;
        rule.IsDeleted = true;
        rule.DeletedDate = DateTime.Now;
        await CommonFeeRuleService.UpdateAsync(rule);

        var result = await SyncCommonFeeRule(rule);
        ShowSuccess($"Common fee deleted and resynced. Removed unpaid records: {result.removed}, paid/partial/receipt records kept: {result.protectedCount}.");
        await LoadData();
    }

    private async Task<(int created, int linked, int removed, int protectedCount)> SyncCommonFeeRule(CommonFeeRule rule)
    {
        var created = 0;
        var linked = 0;
        var removed = 0;
        var protectedCount = 0;

        if (rule.IsDeleted || !rule.IsActive)
        {
            var matchingFees = fees.Where(f => IsSameCommonFee(f, rule)).ToList();
            foreach (var fee in matchingFees)
            {
                if (IsProtectedFee(fee))
                {
                    if (string.IsNullOrWhiteSpace(fee.CommonFeeRuleId))
                    {
                        fee.CommonFeeRuleId = rule.Id;
                        await FeeService.UpdateAsync(fee);
                    }
                    protectedCount++;
                    continue;
                }

                await FeeService.DeleteAsync(fee.Id);
                removed++;
            }

            rule.LastSyncedDate = DateTime.Now;
            await CommonFeeRuleService.UpdateAsync(rule);
            return (created, linked, removed, protectedCount);
        }

        var targetStudents = students.Where(s =>
            s.IsActive &&
            s.SessionId == rule.SessionId &&
            s.ClassSectionId == rule.ClassSectionId).ToList();

        var session = sessions.FirstOrDefault(s => s.Id == rule.SessionId) ?? new AcademicSession { Id = rule.SessionId, Name = rule.SessionName };
        var classSection = classSections.FirstOrDefault(c => c.Id == rule.ClassSectionId) ?? new ClassSection
        {
            Id = rule.ClassSectionId,
            SessionId = rule.SessionId,
            SessionName = rule.SessionName,
            ClassName = rule.ClassSectionName,
            SectionName = string.Empty
        };
        var head = feeHeads.FirstOrDefault(h => h.Id == rule.FeeHeadId) ?? new FeeHead { Id = rule.FeeHeadId, Name = rule.FeeHeadName };

        foreach (var student in targetStudents)
        {
            var existing = fees.FirstOrDefault(f => IsSameCommonFee(f, rule, student.Id));
            if (existing == null)
            {
                await FeeService.AddAsync(CreateFeeRecord(student, session, classSection, head, rule.Amount, rule.FeeMonth, rule.DueDate, rule.Remarks, "Common", rule.Id));
                created++;
                continue;
            }

            if (string.IsNullOrWhiteSpace(existing.CommonFeeRuleId))
            {
                existing.CommonFeeRuleId = rule.Id;
                linked++;
            }

            if (IsProtectedFee(existing))
            {
                protectedCount++;
                await FeeService.UpdateAsync(existing);
                continue;
            }

            existing.SessionName = rule.SessionName;
            existing.ClassSectionName = rule.ClassSectionName;
            existing.FeeType = rule.FeeHeadName;
            existing.Amount = rule.Amount;
            existing.DueDate = rule.DueDate;
            existing.Remarks = rule.Remarks;
            existing.LastUpdated = DateTime.Now;
            await FeeService.UpdateAsync(existing);
        }

        rule.LastSyncedDate = DateTime.Now;
        await CommonFeeRuleService.UpdateAsync(rule);
        return (created, linked, removed, protectedCount);
    }

    private async Task EnsureCommonFeeRulesForExistingFees()
    {
        var commonFeesWithoutRule = fees
            .Where(f => f.ChargeType == "Common" && string.IsNullOrWhiteSpace(f.CommonFeeRuleId))
            .ToList();

        if (!commonFeesWithoutRule.Any())
        {
            return;
        }

        var groups = commonFeesWithoutRule.GroupBy(f => new
        {
            f.SessionId,
            f.SessionName,
            f.ClassSectionId,
            f.ClassSectionName,
            f.FeeHeadId,
            f.FeeType,
            f.FeeMonth,
            f.Amount,
            f.DueDate,
            f.Remarks
        });

        foreach (var group in groups)
        {
            var key = group.Key;
            var rule = commonFeeRules.FirstOrDefault(r =>
                r.SessionId == key.SessionId &&
                r.ClassSectionId == key.ClassSectionId &&
                r.FeeHeadId == key.FeeHeadId &&
                r.FeeMonth == key.FeeMonth &&
                r.Amount == key.Amount &&
                r.DueDate.Date == key.DueDate.Date);

            if (rule == null)
            {
                rule = new CommonFeeRule
                {
                    SessionId = key.SessionId,
                    SessionName = key.SessionName,
                    ClassSectionId = key.ClassSectionId,
                    ClassSectionName = key.ClassSectionName,
                    FeeHeadId = key.FeeHeadId,
                    FeeHeadName = key.FeeType,
                    FeeMonth = key.FeeMonth,
                    Amount = key.Amount,
                    DueDate = key.DueDate,
                    Remarks = key.Remarks,
                    IsActive = true,
                    IsDeleted = false,
                    CreatedDate = group.Min(f => f.CreatedDate)
                };
                await CommonFeeRuleService.AddAsync(rule);
                commonFeeRules.Add(rule);
            }

            foreach (var fee in group)
            {
                fee.CommonFeeRuleId = rule.Id;
                await FeeService.UpdateAsync(fee);
            }
        }
    }

    private bool IsSameCommonFee(FeeRecord fee, CommonFeeRule rule, string? studentId = null)
    {
        if (!string.IsNullOrWhiteSpace(studentId) && fee.StudentId != studentId)
        {
            return false;
        }

        if (fee.ChargeType != "Common")
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(fee.CommonFeeRuleId) && fee.CommonFeeRuleId == rule.Id)
        {
            return true;
        }

        return fee.SessionId == rule.SessionId &&
            fee.ClassSectionId == rule.ClassSectionId &&
            fee.FeeHeadId == rule.FeeHeadId &&
            fee.FeeMonth == rule.FeeMonth &&
            fee.AcademicYear == rule.SessionName;
    }

    private bool IsProtectedFee(FeeRecord fee)
    {
        return fee.PaidAmount > 0 ||
            fee.Status == "Paid" ||
            fee.Status == "Partial" ||
            !string.IsNullOrWhiteSpace(fee.ReceiptNumber) ||
            receipts.Any(r => r.Items.Any(i => i.FeeRecordId == fee.Id));
    }

    private async Task ApplyStudentFee()
    {
        var student = students.FirstOrDefault(s => s.Id == studentFeeStudentId);
        var head = feeHeads.FirstOrDefault(h => h.Id == studentFeeHeadId);

        if (student == null || head == null || studentAmount <= 0)
        {
            ShowError("Student, fee head, and amount are required.");
            return;
        }

        var session = sessions.FirstOrDefault(s => s.Id == student.SessionId) ?? new AcademicSession { Id = student.SessionId, Name = student.SessionName };
        var classSection = classSections.FirstOrDefault(c => c.Id == student.ClassSectionId) ?? new ClassSection
        {
            Id = student.ClassSectionId,
            SessionId = student.SessionId,
            SessionName = student.SessionName,
            ClassName = student.Class,
            SectionName = student.Section
        };

        await FeeService.AddAsync(CreateFeeRecord(student, session, classSection, head, studentAmount, studentMonth, studentDueDate, studentRemarks, "Student"));
        ShowSuccess("Student-only fee applied successfully.");
        studentFeeHeadId = string.Empty;
        studentAmount = 0;
        studentRemarks = string.Empty;
        await LoadData();
    }

    private FeeRecord CreateFeeRecord(Student student, AcademicSession session, ClassSection classSection, FeeHead head, decimal amount, string month, DateTime dueDate, string remarks, string chargeType, string commonFeeRuleId = "")
    {
        return new FeeRecord
        {
            StudentId = student.Id,
            StudentName = $"{student.FirstName} {student.LastName}".Trim(),
            StudentClass = $"{student.Class}-{student.Section}",
            RollNumber = student.RollNumber,
            SessionId = session.Id,
            SessionName = session.Name,
            ClassSectionId = classSection.Id,
            ClassSectionName = classSection.DisplayName,
            AcademicYear = session.Name,
            FeeHeadId = head.Id,
            FeeType = head.Name,
            FeeMonth = month,
            ChargeType = chargeType,
            CommonFeeRuleId = commonFeeRuleId,
            Amount = amount,
            DueDate = dueDate,
            Status = "Pending",
            Remarks = remarks,
            CreatedDate = DateTime.Now
        };
    }


